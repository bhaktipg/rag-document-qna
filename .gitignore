# =============================================================================
# Environment & Secrets
# =============================================================================
.env
.env.local
.env.*.local

# =============================================================================
# Python
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd

# Virtual environments
venv/
.venv/
env/
ENV/

# Distribution / packaging
*.egg
*.egg-info/
dist/
build/
.eggs/

# pip editable install artifacts
__editable__*
*.pth

# Testing & coverage
.pytest_cache/
.coverage
htmlcov/
.tox/
*.log

# MyPy
.mypy_cache/
.dmypy.json

# =============================================================================
# Data & Generated Files (do NOT commit user documents or vector DB)
# =============================================================================
# Drop uploaded documents into data/ locally — don't commit them
data/*
!data/.gitkeep

# ChromaDB is a local runtime artifact — re-generated on first ingest
chroma_db/

# =============================================================================
# macOS
# =============================================================================
.DS_Store
.AppleDouble
.LSOverride

# =============================================================================
# IDEs & Editors
# =============================================================================
.vscode/
.idea/
*.swp
*.swo
*~

# =============================================================================
# Jupyter
# =============================================================================
.ipynb_checkpoints/
*.ipynb

# =============================================================================
# Eval outputs  (keep the question dataset; ignore generated result files)
# =============================================================================
eval/results*.json
eval/results/

# =============================================================================
# Docker runtime
# =============================================================================
# (Dockerfile and docker-compose.yml are kept — they describe infrastructure)
# Ignore any runtime override files
docker-compose.override.yml

# =============================================================================
# Temp / scratch
# =============================================================================
data/temp/
