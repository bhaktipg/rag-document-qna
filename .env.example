# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file to git.
# =============================================================================

# --- LLM Backend -----------------------------------------------------------
# "ollama" = fully local inference (no API key needed)
# "groq"   = Groq Cloud API (fast, requires GROQ_API_KEY)
LLM_PROVIDER=ollama

# Ollama settings
OLLAMA_MODEL=llama3.1:8b
# Where Ollama is running. Leave blank for localhost (default).
# Set to "http://ollama:11434" when running via docker-compose.
OLLAMA_HOST=

# Groq settings (only needed when LLM_PROVIDER=groq)
GROQ_API_KEY=your_groq_key_here
GROQ_MODEL=llama-3.1-8b-instant

# --- Embeddings & Retrieval ------------------------------------------------
EMBEDDING_MODEL=all-MiniLM-L6-v2
CHROMA_PERSIST_DIR=./chroma_db
TOP_K_RETRIEVAL=5

# --- Chunking (used at ingest time) ----------------------------------------
CHUNK_SIZE=512
CHUNK_OVERLAP=50